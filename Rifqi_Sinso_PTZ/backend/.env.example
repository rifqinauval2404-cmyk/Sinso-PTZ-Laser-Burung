# Device bridge (same defaults as the old root server.js)
DEVICE_IP=192.168.1.60
DEVICE_PORT=4196

# Backend HTTP/WS port - deliberately different from the old bridge's 8765
# so both can run side by side during migration testing.
PORT=3001

# Shared API key checked on every REST request (X-Api-Key header) and on
# WebSocket connect (?key= query param). Set a real secret before deploying.
API_KEY=change-me

# MySQL connection
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=sinso
MYSQL_PASSWORD=change-me
MYSQL_DATABASE=sinso_ptz

# Comma-separated list of origins allowed to call the API/WS from a browser
# (the Vite dev server origin in development, e.g. http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
